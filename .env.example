# Optional: enable LLM-based scoring (costs money). Default is false.
LLM_ENABLED=false

# If LLM_ENABLED=true, set one of these:
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Scoring threshold (0-100). Jobs below this are filtered out.
SCORE_THRESHOLD=65

# Maximum results kept per fetch run
MAX_RESULTS_PER_RUN=50

# Freshness window in days (only keep jobs posted within this window)
FRESHNESS_DAYS=3

# Fetch interval in minutes
FETCH_INTERVAL_MINUTES=30

# Database: SQLite (default) or Supabase
# To use Supabase, set both SUPABASE_URL and SUPABASE_KEY.
# Get these from: Supabase Dashboard > Project Settings > API
# Then run supabase_schema.sql in the SQL Editor.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=eyJhbGciOi...

# SQLite database path (used when Supabase is not configured)
DB_PATH=jobs.db

# Excel output path
EXCEL_PATH=job_tracker.xlsx

# Daily application goal reminder (via Gmail)
# Sends an email at NOTIFY_HOUR if you haven't applied to DAILY_GOAL jobs.
# Requires a Gmail App Password: Google Account > Security > App Passwords
# NOTIFY_EMAIL=your.email@gmail.com
# GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
DAILY_GOAL=15
NOTIFY_HOUR=21
